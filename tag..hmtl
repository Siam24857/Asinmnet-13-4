<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Job Application Tracker</title>

<link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
*{
  font-family: "Open Sans", sans-serif;
}
</style>
</head>

<body class="bg-[#F8FAFC] p-4 md:p-0">

<header class="md:pl-[80px] md:pt-[60px]">
  <h1 class="text-3xl font-bold">Job Application Tracker</h1>

  <section class="mt-6 gap-3 grid grid-cols-1 md:grid-cols-3">

    <div class="w-full md:w-[360px] bg-white p-5 rounded-2xl">
      <h2 class="mb-5 font-bold">Total Applications</h2>
      <span id="totalCount" class="font-bold text-xl">8</span>
    </div>

    <div class="w-full md:w-[360px] bg-white p-5 rounded-2xl">
      <h2 class="mb-5 font-bold">Interview</h2>
      <span id="interviewCount" class="font-bold text-xl">0</span>
    </div>

    <div class="w-full md:w-[360px] bg-white p-5 rounded-2xl">
      <h2 class="mb-5 font-bold">Rejected</h2>
      <span id="rejectedCount" class="font-bold text-xl">0</span>
    </div>

  </section>
</header>

<!-- Jobs Section -->
<div id="jobsSection" class="md:pl-[80px] md:pt-[60px] mt-6 md:mt-0">

  <div class="flex justify-between items-center mb-3">
    <h2 class="text-2xl font-bold">Available Jobs</h2>
    <span id="tabCount" class="bg-gray-200 px-3 py-1 rounded-full font-bold">8</span>
  </div>

  <div class="mb-4">
    <button onclick="showAll()" class="btn btn-sm mx-1">All</button>
    <button onclick="showInterview()" class="btn btn-sm mx-1">Interview</button>
    <button onclick="showRejected()" class="btn btn-sm mx-1">Rejected</button>
  </div>

  <div id="jobContainer" class="grid grid-cols-1 gap-4">

  </div>

  <div id="emptyState" class="hidden mt-10 text-center">
    <img src="https://cdn-icons-png.flaticon.com/512/4076/4076478.png" alt="No jobs" class="w-40 mx-auto mb-4">
    <h3 class="text-xl font-bold">No Jobs Available</h3>
    <p class="text-gray-500">Please change job status to see jobs here.</p>
  </div>

</div>

<script>

let jobs = [
{
  id: 1,
  company: "WebFlow Agency",
  position: "Web Designer",
  location: "Los Angeles, CA",
  jobType: "Part-time",
  salary: "$80,000",
  description: "Create stunning web experiences for high-profile clients.",
  applyStatus: "NOT APPLIED",
  status: "all"
},
{
  id: 2,
  company: "Google",
  position: "Frontend Developer",
  location: "Mountain View, CA",
  jobType: "Full-time",
  salary: "$120,000",
  description: "Build amazing user interfaces for Google products.",
  applyStatus: "NOT APPLIED",
  status: "all"
},
{
  id: 3,
  company: "Apple",
  position: "UI Designer",
  location: "Cupertino, CA",
  jobType: "Full-time",
  salary: "$110,000",
  description: "Design beautiful interfaces for Apple products.",
  applyStatus: "NOT APPLIED",
  status: "all"
},
{
  id: 4,
  company: "Microsoft",
  position: "Software Engineer",
  location: "Redmond, WA",
  jobType: "Full-time",
  salary: "$100,000",
  description: "Develop cloud solutions for enterprise clients.",
  applyStatus: "NOT APPLIED",
  status: "all"
},
{
  id: 5,
  company: "Amazon",
  position: "Full Stack Developer",
  location: "Seattle, WA",
  jobType: "Full-time",
  salary: "$115,000",
  description: "Build scalable web applications for Amazon.",
  applyStatus: "NOT APPLIED",
  status: "all"
},
{
  id: 6,
  company: "Netflix",
  position: "Frontend Engineer",
  location: "Los Gatos, CA",
  jobType: "Full-time",
  salary: "$130,000",
  description: "Create engaging user experiences for streaming platform.",
  applyStatus: "NOT APPLIED",
  status: "all"
},
{
  id: 7,
  company: "Spotify",
  position: "Product Designer",
  location: "New York, NY",
  jobType: "Contract",
  salary: "$90,000",
  description: "Design music streaming features for mobile and web.",
  applyStatus: "NOT APPLIED",
  status: "all"
},
{
  id: 8,
  company: "Adobe",
  position: "Creative Developer",
  location: "San Jose, CA",
  jobType: "Full-time",
  salary: "$105,000",
  description: "Build creative tools for designers and artists.",
  applyStatus: "NOT APPLIED",
  status: "all"
}
];

let currentTab = "all";

function showJobs(){

  const container = document.getElementById("jobContainer");
  container.innerHTML = "";

  let count = 0;

  for(let i = 0; i < jobs.length; i++){

    if(currentTab == "all" || jobs[i].status == currentTab){

      count++;

      container.innerHTML +=
        "<div class='bg-white p-4 rounded-xl shadow relative'>" +
        "<button onclick='deleteJob("+jobs[i].id+")' class='absolute top-2 right-2 text-gray-400 hover:text-red-500'><i class='fa-solid fa-trash-can'></i></button>" +
        "<h3 class='font-bold text-xl pr-6'>" + jobs[i].position + "</h3>" +
        "<p class='text-gray-600 font-semibold'>" + jobs[i].company + "</p>" +
        "<p class='text-gray-500 text-sm'>" + jobs[i].location + "</p>" +
        "<div class='my-2'>" +
        "<span class='bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded font-semibold inline-block'>" + jobs[i].applyStatus + "</span>" +
        "</div>" +
        "<div class='flex gap-2 my-2'>" +
        "<span class='bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded'>" + jobs[i].jobType + "</span>" +
        "<span class='bg-green-100 text-green-800 text-xs px-2 py-1 rounded'>" + jobs[i].salary + "</span>" +
        "</div>" +
        "<p class='text-gray-600 text-sm mb-3'>" + jobs[i].description + "</p>" +
        "<div class='flex gap-2'>" +
        "<button onclick='setInterview("+jobs[i].id+")' class='btn btn-success btn-sm'>Interview</button>" +
        "<button onclick='setRejected("+jobs[i].id+")' class='btn btn-error btn-sm'>Rejected</button>" +
        "</div>" +
        "</div>";
    }
  }

  document.getElementById("tabCount").innerText = count;

  if(count == 0){
    document.getElementById("emptyState").classList.remove("hidden");
  }else{
    document.getElementById("emptyState").classList.add("hidden");
  }

  updateDashboard();
}

function setInterview(id){

  for(let i = 0; i < jobs.length; i++){

    if(jobs[i].id == id){

      if(jobs[i].status == "interview"){
        jobs[i].status = "all";
        jobs[i].applyStatus = "NOT APPLIED";
      }else{
        jobs[i].status = "interview";
        jobs[i].applyStatus = "INTERVIEW";
      }

    }
  }

  showJobs();
}

function setRejected(id){

  for(let i = 0; i < jobs.length; i++){

    if(jobs[i].id == id){

      if(jobs[i].status == "rejected"){
        jobs[i].status = "all";
        jobs[i].applyStatus = "NOT APPLIED";
      }else{
        jobs[i].status = "rejected";
        jobs[i].applyStatus = "REJECTED";
      }

    }
  }

  showJobs();
}

function deleteJob(id){

  for(let i = 0; i < jobs.length; i++){

    if(jobs[i].id == id){
      jobs.splice(i,1);
      break;
    }
  }

  showJobs();
}

function updateDashboard(){

  let total = jobs.length;
  let interview = 0;
  let rejected = 0;

  for(let i = 0; i < jobs.length; i++){

    if(jobs[i].status == "interview"){
      interview++;
    }

    if(jobs[i].status == "rejected"){
      rejected++;
    }
  }

  document.getElementById("totalCount").innerText = total;
  document.getElementById("interviewCount").innerText = interview;
  document.getElementById("rejectedCount").innerText = rejected;
}

function showAll(){
  currentTab = "all";
  showJobs();
}

function showInterview(){
  currentTab = "interview";
  showJobs();
}

function showRejected(){
  currentTab = "rejected";
  showJobs();
}

// Initialize with some interview and rejected jobs to demonstrate counts
// Set 3 jobs to interview and 2 jobs to rejected for demo
jobs[2].status = "interview";
jobs[2].applyStatus = "INTERVIEW";
jobs[5].status = "interview";
jobs[5].applyStatus = "INTERVIEW";
jobs[6].status = "rejected";
jobs[6].applyStatus = "REJECTED";
jobs[7].status = "rejected";
jobs[7].applyStatus = "REJECTED";

showJobs();

</script>

</body>
</html>